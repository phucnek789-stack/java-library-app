<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" styleClass="Container" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pnhp.libraryapp.PrimaryController">
   <children>
      <Label alignment="CENTER" styleClass="Subject" text="HỆ THỐNG QUẢN LÝ THƯ VIỆN" />
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Label text="Chọn cấu hình phí mượn:">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
            <ComboBox fx:id="cbBorrowTypes" prefWidth="150.0" styleClass="ComboBox" />
         </children>
      </HBox>
      <Button mnemonicParsing="false" onAction="#switchToBookList" styleClass="Button" text="Xem Danh Sách Sách &amp; Mượn Sách" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
